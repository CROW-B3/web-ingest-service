            },
          ],
        },
      ],
      "durable_objects": {
        "bindings": [
          {
            "class_name": "CrowWebSession",
            "name": "CROW_WEB_SESSION",
          },
        ],
      },
    },
    "production": {
      "name": "crow-web-ingest-worker",
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "crow-web-ingest-service-db",
          "database_id": "58b32c68-d807-4b42-9075-08a12078bdf7",
          "remote": true
        }
