{
  "name": "web-ingest-worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "deploy": "wrangler deploy --env=\"\"",
    "deploy:dev": "wrangler deploy --env dev",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "prepare": "husky",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "bun prettier src/ --write"
  },
  "packageManager": "bun@1.3.3",
  "dependencies": {
    "husky": "^9.1.7"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.0.1",
    "@commitlint/config-conventional": "^20.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "typescript": "^5.5.2",
    "wrangler": "^4.50.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
