{
  "name": "web-ingest-worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "bundle:rrweb": "bun scripts/bundle-rrweb.ts",
    "prebuild": "bun run bundle:rrweb",
    "deploy": "bun run bundle:rrweb && wrangler deploy --env production",
    "deploy:dev": "bun run bundle:rrweb && wrangler deploy --env dev",
    "dev": "bun run bundle:rrweb && wrangler dev --env local --port 8013 --inspector-port 9242 | pino-pretty",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "prepare": "husky",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "bun prettier src/ --write"
  },
  "packageManager": "bun@1.3.3",
  "dependencies": {
    "@cloudflare/puppeteer": "^1.0.6",
    "rrweb": "2.0.0-alpha.20",
    "@microlabs/otel-cf-workers": "^1.0.0-rc.52",
    "drizzle-orm": "^0.45.1",
    "husky": "^9.1.7",
    "pino": "^10.1.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@commitlint/config-conventional": "^20.0.0",
    "drizzle-kit": "^0.31.8",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.7",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.6.2",
    "typescript": "^5.5.2",
    "wrangler": "^4.59.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
